// test4_loops.cvm
// Tests: while loops, counters, accumulators, nested loops

// --- Count from 1 to 5 ---
let i = 1;
while (i <= 5) {
    print i;
    i = i + 1;
}
// expects: 1 2 3 4 5

// --- Sum 1..10 ---
let sum = 0;
let n = 1;
while (n <= 10) {
    sum = sum + n;
    n = n + 1;
}
print sum;   // expects: 55

// --- Factorial of 6 ---
let fact = 1;
let k = 1;
while (k <= 6) {
    fact = fact * k;
    k = k + 1;
}
print fact;  // expects: 720

// --- Countdown ---
let c = 5;
while (c > 0) {
    print c;
    c = c - 1;
}
// expects: 5 4 3 2 1

// --- Nested loops: multiplication table 1..3 x 1..3 ---
let row = 1;
while (row <= 3) {
    let col = 1;
    while (col <= 3) {
        print row * col;
        col = col + 1;
    }
    row = row + 1;
}
// expects: 1 2 3  2 4 6  3 6 9
